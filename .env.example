# Supabase (required for saving leads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Table name for course leads (default: course_leads)
SUPABASE_TABLE_LEADS=course_leads

# Meta Pixel ID for Facebook lead ads (optional; leave empty to skip Pixel)
FACEBOOK_PIXEL_ID=
